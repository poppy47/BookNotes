<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Book - Book Notes</title>
    <link rel="stylesheet" href="/bootstrap-css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/main.css">
</head>

<body class="bg-light d-flex flex-column min-vh-100">

<%- include("../partials/header.ejs") %>

<main class="flex-grow-1 py-5">
    <div class="container" style="max-width: 600px;">
        <h1 class="mb-4 text-center">Edit Book Notes</h1> 
        
        <form action="/admin/edit/<%= Books.isbn %>" method="post" class="p-4 bg-white border rounded shadow-sm mb-5"> 
        
            <div class="mb-3">
                <label class="form-label fw-bold" for="bookName">Book Name</label>
                <input type="text" name="name" id="bookName" value="<%= Books.title %>" class="form-control" required> 
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold" for="authorName">Author Name</label>
                <input type="text" name="author" id="authorName" value="<%= Books.author %>" class="form-control" required> 
            </div>

            <div class="mb-3">
                <label for="isbn" class="form-label fw-bold">ISBN NO (Cannot be changed)</label>
                <input type="number" name="isbn" id="isbn" value="<%= Books.isbn %>" class="form-control" readonly> 
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold d-block">Rating</label>
                <div class="d-flex flex-wrap gap-y-2">
                    <% for(let i = 1; i <= 10; i++) { %>
                        <div class="form-check form-check-inline d-flex align-items-center gap-1 me-2">
                            <input 
                                class="form-check-input m-0" 
                                type="radio" 
                                name="rating" 
                                id="rating<%= i %>" 
                                value="<%= i %>" 
                                <%= Number(Books.rating) === i ? 'checked' : '' %>
                                <%= i === 1 ? 'required' : '' %>>
                            <label class="form-check-label ps-1" for="rating<%= i %>"><%= i %></label>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label fw-bold">Book Description</label>
                <textarea name="description" id="description" rows="2" class="form-control"><%= Books.description %></textarea>
            </div>

            <div class="mb-4">
                <label for="textarea" class="form-label fw-bold">Article / Detailed Notes</label> 
                <textarea name="article" id="textarea" rows="5" class="form-control"><%= Books.notes || Books.article || '' %></textarea>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Save Changes</button>
        </form>
    </div>
</main>

<%- include("../partials/footer.ejs") %>

<script src="/bootstrap-js/bootstrap.bundle.min.js"></script>
</body>
</html>
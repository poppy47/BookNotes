<%- include("./partials/header.ejs") %>

    <main class="container my-5 flex-grow-1">

        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
            <h1 class="fw-bold text-dark mb-0">My Book Notes</h1>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted fw-semibold">Total Reads: <%= Books.length %></span>
                <% if (locals.user && user.isAdmin) { %>
                    <a href="/admin/add" class="btn btn-sm btn-success rounded-pill px-3 fw-semibold">
                        + Add Book
                    </a>
                    <a href="/admin/logout" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold">
                        🚪 Logout
                    </a>
                    <% } %>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-lg-2 g-4">
            <% Books.forEach((book)=> { %>
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden transition-hover">
                        <div class="row g-0 h-100">

                            <div class="col-4 col-sm-3 d-flex align-items-start p-3 bg-white">
                                <img class="book-cover" data-isbn="<%= book.isbn %>"
                                    src="https://covers.openlibrary.org/b/isbn/<%= book.isbn %>-L.jpg"
                                    alt="<%= book.title %> cover" class="img-fluid rounded shadow-sm w-100"
                                    style="object-fit: contain; height: auto; max-height: 190px;">
                            </div>

                            <div
                                class="col-8 col-sm-9 card-body d-flex flex-column justify-content-between p-4 ps-0 ps-sm-2">
                                <div>
                                    <div class="d-flex flex-wrap justify-content-between align-items-start mb-1 gap-2">
                                        <h2 class="h6 card-title fw-bold text-dark mb-0 flex-grow-1 me-2"
                                            style="max-width: 70%; line-height: 1.4;">
                                            <%= book.title %>
                                        </h2>
                                        <span
                                            class="badge bg-warning text-dark rounded-pill px-2 py-1 fw-bold small flex-shrink-0">
                                            ⭐ <%= book.rating %>/10
                                        </span>
                                    </div>

                                    <h4 class="text-muted mb-3 small" style="font-size: 0.85rem;">by <%= book.author %>
                                    </h4>

                                    <p class="card-text text-secondary small line-clamp-3 mb-0">
                                        <%= book.description %>
                                    </p>
                                </div>

                                <div class="mt-3 pt-2 border-top d-flex flex-column gap-2 text-muted small">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>📅 Read: <%= new Date(book.read_date).toLocaleDateString('en-US', {
                                                month: 'short' , year: 'numeric' }) %></span>
                                        <a href="/books/<%= book.isbn %>"
                                            class="btn btn-sm btn-outline-primary rounded-pill px-3">View Notes</a>
                                    </div>

                                    <% if (locals.user && user.isAdmin) { %>
                                        <div class="d-flex justify-content-end gap-2 mt-1 pt-2 border-top border-light">
                                            <a href="/admin/edit/<%= book.isbn %>"
                                                class="btn btn-sm btn-warning text-dark px-3 rounded-pill fw-semibold"
                                                style="font-size: 0.75rem;">
                                                ✏️ Edit
                                            </a>
                                            <form action="/admin/delete/<%= book.isbn %>" method="POST" class="d-inline"
                                                onsubmit="return confirm('Are you sure you want to delete this book?');">
                                                <button type="submit"
                                                    class="btn btn-sm btn-danger px-3 rounded-pill fw-semibold"
                                                    style="font-size: 0.75rem;">
                                                    🗑️ Delete
                                                </button>
                                            </form>
                                        </div>
                                        <% } %>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
        </div>

    </main>

    <%- include("./partials/footer.ejs") %>

        <script src="/bootstrap-js/bootstrap.bundle.min.js"></script>
        </body>

        </html>
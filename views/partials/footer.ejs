<footer class="bg-dark text-light py-3 mt-auto">
  <div class="container">
    <div class="row align-items-center justify-content-between gy-3">
      
      <div class="col-md-4 text-center text-md-start">
        <h5 class="fw-bold mb-1 text-white">📚 BookNotes</h5>
        <p class="text-muted small mb-0">Your personal reading archive & insights.</p>
      </div>

      <div class="col-md-4 text-center">
        <div class="d-flex justify-content-center gap-4">
          <a href="/" class="text-secondary text-decoration-none nav-hover">Home</a>
          <a href="https://openlibrary.org" target="_blank" class="text-secondary text-decoration-none nav-hover">Open Library</a>
        </div>
      </div>

      <div class="col-md-4 text-center text-md-end text-muted small">
        <span>&copy; 2026 BookNotes. All rights reserved.</span>
      </div>

    </div>
  </div>

  <script>
    document.querySelectorAll('img.book-cover').forEach(img => {
        img.onerror = function() {
            if (this.src.includes('openlibrary')) {
                this.src = `https://books.google.com/books/content?vid=ISBN${this.dataset.isbn}&printsec=frontcover&img=1&zoom=1&source=gbs_api`;
                this.onerror = function() {
                    this.src = 'https://placehold.co/140x200/1a1a2e/ffffff?text=No+Cover';
                };
            }
        };
    });
  </script>
</footer>